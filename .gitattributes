# Default normalization for text files.
* text=auto

# Unity YAML assets should stay diffable unless explicitly overridden below.
*.[Uu][Nn][Ii][Tt][Yy] text eol=lf
*.[Pp][Rr][Ee][Ff][Aa][Bb] text eol=lf
*.[Aa][Ss][Ss][Ee][Tt] text eol=lf
*.[Mm][Aa][Tt] text eol=lf
*.[Aa][Nn][Ii][Mm] text eol=lf
*.[Cc][Oo][Nn][Tt][Rr][Oo][Ll][Ll][Ee][Rr] text eol=lf
*.[Mm][Ee][Tt][Aa] text eol=lf
*.[Ss][Hh][Aa][Dd][Ee][Rr][Gg][Rr][Aa][Pp][Hh] text eol=lf
*.[Vv][Ff][Xx] text eol=lf

# Unity can serialize baked lighting payloads as binary .asset files.
**/[Ll][Ii][Gg][Hh][Tt][Ii][Nn][Gg][Dd][Aa][Tt][Aa].asset filter=lfs diff=lfs merge=lfs -text -eol

