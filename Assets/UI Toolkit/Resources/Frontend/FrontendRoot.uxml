<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="FrontendTheme.uss" />
    <ui:VisualElement name="FrontendRoot" class="frontend-root">
        <ui:VisualElement name="BaseLayer" class="screen-layer base-layer" />
        <ui:VisualElement name="OverlayLayer" class="screen-layer overlay-layer" />
    </ui:VisualElement>
</ui:UXML>
