    _translations:
    - _languageId: en
      _text: RIGHT TREAD
    - _languageId: es
      _text: ORUGA DER
  - _key: ui.character_selection.info.arcade_style.gamepad.line1
    _translations:
    - _languageId: en
      _text: Drive with Left Stick using arcade steering.
    - _languageId: es
      _text: Conduce con Left Stick con giro arcade.
  - _key: ui.character_selection.info.arcade_style.gamepad.line2
    _translations:
    - _languageId: en
      _text: Aim with Right Stick. Fire with RT.
    - _languageId: es
      _text: Apunta con Right Stick. Dispara con RT.
  - _key: ui.character_selection.info.arcade_style.keyboard.line1
    _translations:
    - _languageId: en
      _text: Drive with W/S + A/D using arcade steering.
    - _languageId: es
      _text: Conduce con W/S + A/D con giro arcade.
  - _key: ui.character_selection.info.arcade_style.keyboard.line2
    _translations:
    - _languageId: en
      _text: Aim with arrows. Fire with Space.
    - _languageId: es
      _text: Apunta con flechas. Dispara con Espacio.
  - _key: ui.character_selection.info.full_control.gamepad.ai
    _translations:
    - _languageId: en
      _text: After a short pause, AI takes over. Aim or fire to take it back.
    - _languageId: es
      _text: Tras una pausa corta, la IA toma la torreta. Apunta o dispara para recuperarla.
  - _key: ui.character_selection.info.full_control.gamepad.line1
    _translations:
    - _languageId: en
      _text: Drive with Left Stick.
    - _languageId: es
      _text: Conduce con Left Stick.
  - _key: ui.character_selection.info.full_control.gamepad.line2
    _translations:
    - _languageId: en
      _text: Aim with Right Stick. Fire with RT.
    - _languageId: es
      _text: Apunta con Right Stick. Dispara con RT.
  - _key: ui.character_selection.info.full_control.keyboard.ai
    _translations:
    - _languageId: en
      _text: After a short pause, AI takes over. Aim or fire to take it back.
    - _languageId: es
      _text: Tras una pausa corta, la IA toma la torreta. Apunta o dispara para recuperarla.
  - _key: ui.character_selection.info.full_control.keyboard.line1
    _translations:
    - _languageId: en
      _text: Drive with W/S + A/D.
    - _languageId: es
      _text: Conduce con W/S + A/D.
  - _key: ui.character_selection.info.full_control.keyboard.line2
    _translations:
    - _languageId: en
      _text: Aim with arrows. Fire with Space.
    - _languageId: es
      _text: Apunta con flechas. Dispara con Espacio.
  - _key: ui.character_selection.info.heading
    _translations:
    - _languageId: en
      _text: CURRENT SETUP
    - _languageId: es
      _text: CONFIGURACION
  - _key: ui.character_selection.info.tracks_only.gamepad.line1
    _translations:
    - _languageId: en
      _text: One stick per tread.
    - _languageId: es
      _text: Un stick por oruga.
  - _key: ui.character_selection.info.tracks_only.gamepad.line2
    _translations:
    - _languageId: en
      _text: AI gunner is always active.
    - _languageId: es
      _text: El artillero IA siempre esta activo.
  - _key: ui.character_selection.info.tracks_only.keyboard.line1
    _translations:
    - _languageId: en
      _text: Run each tread yourself.
    - _languageId: es
      _text: Maneja cada oruga por separado.
  - _key: ui.character_selection.info.tracks_only.keyboard.line2
    _translations:
    - _languageId: en
      _text: AI gunner is always active.
    - _languageId: es
      _text: El artillero IA siempre esta activo.
