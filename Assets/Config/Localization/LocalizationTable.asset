      _text: LOCKED IN
    - _languageId: es
      _text: CONFIRMADO
  - _key: ui.character_selection.subtitle.default
    _translations:
    - _languageId: en
      _text: Choose your control type and weapon type, then ready up.
    - _languageId: es
      _text: Elige tu control y arma, y confirma.
  - _key: ui.character_selection.subtitle.ready
    _translations:
    - _languageId: en
      _text: Waiting for other players...
    - _languageId: es
      _text: Esperando a los demas...
